<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Error</title>
    <style>body{font-family:Arial,Helvetica,sans-serif;padding:20px}</style>
  </head>
  <body>
    <h1>Error</h1>
    <h2>{{message}}</h2>
    {{#if error.status}}
      <p>Status: {{error.status}}</p>
    {{/if}}
    {{#if error.stack}}
      <pre>{{error.stack}}</pre>
    {{/if}}
  </body>
</html>
