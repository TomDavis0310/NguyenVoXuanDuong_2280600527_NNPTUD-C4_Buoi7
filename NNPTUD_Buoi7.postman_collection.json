              "raw": "{\n  \"name\": \"admin\",\n  \"description\": \"Quan tri vien\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/roles",
              "host": ["{{baseUrl}}"],
              "path": ["roles"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create role status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData._id) {",
                  "    pm.collectionVariables.set('roleId', jsonData._id);",
